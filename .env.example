# Database Connection
# For local development (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# 
# For production on Vercel (PostgreSQL):
# You MUST set this in Vercel project environment variables:
# DATABASE_URL="postgres://user:password@host:5432/dbname"

# API Configuration
# Local development
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
# Production (Vercel) - auto-detects based on VERCEL_URL

# Node Environment
NODE_ENV="development"
