generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "sqlite"
  // if DATABASE_URL isn't set, fall back to a local sqlite file (development only)
  url      = env("DATABASE_URL", "file:./dev.db")
}

model User {
  id               String       @id @default(cuid())
  name             String
  email            String       @unique
  password         String
  universitas      String?
  nim              String?
  role             String       @default("USER")
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime     @default(now())
  attendances      Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
